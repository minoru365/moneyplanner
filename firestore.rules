rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── ヘルパー関数 ──
    function signedIn() {
      return request.auth != null;
    }

    // 現在のユーザーが所属する世帯IDを取得
    function userHouseholdId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdId;
    }

    function notRemoved(memberData) {
      return !("removedAt" in memberData) || memberData.removedAt == null;
    }

    function activeMember(householdId) {
      return signedIn()
        && exists(/databases/$(database)/documents/households/$(householdId))
        && userHouseholdId() == householdId
        && exists(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid))
        && notRemoved(get(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid)).data);
    }

    function createsOwnHouseholdInvite(householdId) {
      return existsAfter(/databases/$(database)/documents/households/$(householdId))
        && getAfter(/databases/$(database)/documents/households/$(householdId)).data.createdBy == request.auth.uid
        && existsAfter(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid))
        && notRemoved(getAfter(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid)).data);
    }

    function inviteCodeUsableForHousehold(code, householdId) {
      return code is string
        && exists(/databases/$(database)/documents/inviteCodes/$(code))
        && get(/databases/$(database)/documents/inviteCodes/$(code)).data.householdId == householdId
        && (!('disabledAt' in get(/databases/$(database)/documents/inviteCodes/$(code)).data)
          || get(/databases/$(database)/documents/inviteCodes/$(code)).data.disabledAt == null)
        && (!('expiresAt' in get(/databases/$(database)/documents/inviteCodes/$(code)).data)
          || get(/databases/$(database)/documents/inviteCodes/$(code)).data.expiresAt > request.time);
    }

    // ユーザードキュメント: 本人のみ読み書き可
    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    // 招待コード: コードを知っている認証済みユーザーのみ直接参照する
    match /inviteCodes/{code} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.householdId is string
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time
        && request.resource.data.disabledAt == null
        && (
          activeMember(request.resource.data.householdId)
          || createsOwnHouseholdInvite(request.resource.data.householdId)
        );
      allow update, delete: if signedIn()
        && activeMember(resource.data.householdId);
    }

    // 世帯ドキュメント: 自世帯メンバーのみアクセス可
    match /households/{householdId} {
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow read, update, delete: if activeMember(householdId);

      match /members/{userId} {
        allow read: if activeMember(householdId);
        allow create: if signedIn()
          && (
            activeMember(householdId)
            || (
              request.auth.uid == userId
              && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdId == householdId
            )
          );
        allow update: if activeMember(householdId);
        allow delete: if activeMember(householdId);
      }

      match /joinRequests/{userId} {
        allow read: if activeMember(householdId)
          || (signedIn() && request.auth.uid == userId);

        allow create: if signedIn()
          && request.auth.uid == userId
          && request.resource.data.uid == userId
          && request.resource.data.status == "pending"
          && request.resource.data.inviteCode is string
          && inviteCodeUsableForHousehold(request.resource.data.inviteCode, householdId)
          && request.resource.data.displayName is string
          && request.resource.data.displayName.size() > 0
          && request.resource.data.displayName.size() <= 20;

        allow update: if (
            signedIn()
            && request.auth.uid == userId
            && resource.data.status == "pending"
            && request.resource.data.status == "pending"
            && request.resource.data.uid == userId
            && request.resource.data.inviteCode is string
            && inviteCodeUsableForHousehold(request.resource.data.inviteCode, householdId)
            && request.resource.data.displayName is string
            && request.resource.data.displayName.size() > 0
            && request.resource.data.displayName.size() <= 20
          )
          || activeMember(householdId);

        allow delete: if activeMember(householdId);
      }

      // 世帯配下の全サブコレクション: 自世帯メンバーのみ
      match /{subcollection}/{docId} {
        allow read, write: if activeMember(householdId);
      }
    }
  }
}
